<Window x:Class="StudySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudySystem"
        xmlns:controls="clr-namespace:StudySystem.Controls"
        xmlns:screens="clr-namespace:StudySystem.Screens"
        mc:Ignorable="d"
        Title="Study System" 
        Height="700" 
        Width="1100" 
        MinWidth="800" 
        MinHeight="500" 
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/App.ico"
        WindowState="Maximized">
    <Grid x:Name="MainGrid" Background="#202020">

        <!-- HomeScreen -->
        <screens:HomeScreenView x:Name="HomeScreen" Visibility="Visible"/>

        <!-- StudyScreen -->
        <screens:StudyScreenView x:Name="StudyScreen" Visibility="Collapsed"/>

        <!-- BuilderScreen -->
        <screens:BuilderScreenView x:Name="BuilderScreen" Visibility="Collapsed"/>

        <!-- SettingsScreen -->
        <screens:SettingsScreenView x:Name="SettingsScreen" Visibility="Collapsed"/>

        <!-- CardScreen -->
        <screens:CardScreenView x:Name="CardScreen" Visibility="Collapsed"/>
    </Grid>
</Window>