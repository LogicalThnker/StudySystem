<UserControl x:Class="StudySystem.Screens.SettingsScreenView"
             x:Name="SettingsScreen"
             Visibility="Collapsed"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:StudySystem.Controls"
             xmlns:local="clr-namespace:StudySystem.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#202020" Visibility="Visible">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Middle -->
            <RowDefinition Height="Auto"/> <!-- Bottom -->
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock Text="Settings Screen" Foreground="#C6C6C6"
                       FontSize="36" FontFamily="Segoe UI" Padding="6" Margin="0,0,0,4"
                       HorizontalAlignment="Center" VerticalAlignment="Top">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#3E454B" BlurRadius="0"
                                      ShadowDepth="1" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </Grid>
        <Grid Grid.Row="1">
            <Border Width="1700" Height="860"
                    BorderBrush="#C6C6C6" Background="#292929"
                    BorderThickness="3" CornerRadius="22">
                <Grid>
                    <StackPanel>
                        <Border Width="500" Height="820" BorderBrush="#8A8A8A" BorderThickness="2"
                                HorizontalAlignment="Left" VerticalAlignment="Center" Padding="6"
                                Margin="20,20,0,0" CornerRadius="16">
                            
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <Border Width="500" Height="820" BorderBrush="#8A8A8A" BorderThickness="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="6"
                                Margin="0,20,0,0" CornerRadius="16">
                            
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <Border Width="500" Height="820" BorderBrush="#8A8A8A" BorderThickness="2"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Padding="6"
                                Margin="0,20,20,0" CornerRadius="16">

                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Button x:Name="HomeButton" Padding="6" Margin="0,12,0,0"
                    Content="Back" Style="{StaticResource MenuButtonStyle}"
                    ToolTip="Brings to HomeScreen atm, not true back - WIP"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</UserControl>
